# Environment configuration template
PORT=5000
NODE_ENV=development

# Database configuration (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aptitude_platform?schema=public"

# Authentication secrets
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production"

# Optional Gemini API key (the application falls back to an intelligent mock responder if this is empty)
GEMINI_API_KEY=""

# Nodemailer SMTP credentials for Gmail (App password required in production)
EMAIL_USER="your-gmail-address@gmail.com"
EMAIL_PASS="your-16-character-gmail-app-password"
