{
  "name": "aptitude-learning-platform-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:server": "npm --workspace=server run dev",
    "dev:client": "npm --workspace=client run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:shared": "npm --workspace=shared run build",
    "build:server": "npm --workspace=server run build",
    "build:client": "npm --workspace=client run build",
    "build": "npm run build:shared && npm run build:server && npm run build:client",
    "start": "npm --workspace=server run start",
    "prisma:generate": "npm --workspace=server run prisma:generate",
    "prisma:migrate": "npm --workspace=server run prisma:migrate",
    "prisma:seed": "npm --workspace=server run prisma:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
